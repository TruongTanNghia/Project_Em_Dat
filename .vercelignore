# ─── Backend (Python) — never deployed to Vercel ───
backend/

# ─── Legacy Express FE (frontend/) — replaced by frontend-next/ ───
# We exclude the OLD frontend's server-only files. The frontend-next/ folder
# is what Vercel actually deploys (set as Root Directory).
frontend/server.js
frontend/mcp-server.js
frontend/package.json
frontend/package-lock.json
frontend/node_modules/

# ─── Root-only data dirs (large checkpoints, raw datasets) ───
# Leading slash anchors to repo root, so /models/ matches the repo's
# /models/ folder ONLY — it does NOT match frontend-next/public/models/
# which contains the GLB files needed for 3D viz.
/uploads/
/dataset/
/models/
/training/
/1/
/docs/

# ─── Dev / misc ───
.claude/
.git/
.gitignore
README.md
bao_cao_do_an.*
